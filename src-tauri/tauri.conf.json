{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Forel",
  "version": "0.1.0-alpha.7",
  "identifier": "com.forel.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forel",
        "width": 900,
        "height": 620,
        "minWidth": 720,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBNkNCMzZDMjZDNTNBMjAKUldRZ09zVW1iTE5zMnJVZ0lTc3ZTZ0NrbjBEdXFKdnVMY0U3M2RjNjd3RDcvemUxdEttenc3WU8K",
      "endpoints": [
        "https://github.com/forel-app/forel/releases/latest/download/latest.json"
      ]
    }
  }
}
